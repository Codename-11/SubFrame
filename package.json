{
  "name": "subframe",
  "productName": "SubFrame",
  "version": "1.0.0",
  "description": "SubFrame - Project Management IDE for Claude Code",
  "main": "src/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "build": "esbuild src/renderer/index.js --bundle --outfile=dist/renderer.js --platform=node --external:electron",
    "watch": "esbuild src/renderer/index.js --bundle --outfile=dist/renderer.js --platform=node --external:electron --watch",
    "start": "npm run build && electron .",
    "dev": "node scripts/dev.js",
    "structure": "node scripts/update-structure.js",
    "structure:changed": "node scripts/update-structure.js --changed",
    "find-module": "node scripts/find-module.js",
    "prepare": "git config core.hooksPath .githooks || true",
    "dist": "npm run build && electron-builder --dir",
    "dist:win": "node scripts/dist-win.js",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:unsigned": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "generate-icons": "node scripts/generate-icons.js",
    "init": "node scripts/init.js"
  },
  "keywords": [
    "electron",
    "terminal",
    "claude",
    "subframe",
    "ide",
    "project-management"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.7.0",
    "esbuild": "^0.27.2"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "build": {
    "appId": "com.subframe.ide",
    "productName": "SubFrame",
    "npmRebuild": false,
    "icon": "assets/icon.png",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg"],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": null,
      "icon": "assets/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "src/**/*",
      "dist/**/*",
      "assets/icon.*",
      "assets/icon-*.png",
      "node_modules/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**"
    ]
  }
}
